# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib
scorpio
/audio-scout

# local logging (used in prod)
*.log

# Test binary, build with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Folders and such
/vendor
/target
/bin
/reports

# Run output (logs, results) — directory is tracked via .gitkeep
/output/*
!/output/.gitkeep

# Environment config files
/.env*

# Intellij
/.idea

# VS Code
/.vscode

# Mac hidden files
.DS_Store

# WhiteSource
/.ws
